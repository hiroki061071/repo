<Window x:Class="WxAid3DSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        Title="WxAid3DSharp"
        Width="1280"
        Height="860"
        KeyDown="Window_KeyDown">
    <Grid Background="Black">
        <hx:Viewport3DX x:Name="View"
                BackgroundColor="Black"
                ShowFrameRate="False"
                ShowCoordinateSystem="False"
                ZoomExtentsWhenLoaded="True"
                IsHitTestVisible="False">
            <hx:Viewport3DX.Camera>
                <hx:PerspectiveCamera Position="-120,-260,140"
                                      LookDirection="120,260,-120"
                                      UpDirection="0,0,1"
                                      NearPlaneDistance="0.1"
                                      FarPlaneDistance="10000"/>
            </hx:Viewport3DX.Camera>

            <hx:DirectionalLight3D Direction="-0.7,-0.5,-2" Color="White"/>
            <hx:DirectionalLight3D Direction="0.5,0.4,-1" Color="#555555"/>
            <hx:AmbientLight3D Color="#202020"/>

            <hx:GroupModel3D x:Name="MapGroup">
                <hx:MeshGeometryModel3D x:Name="SeaModel"/>
                <hx:MeshGeometryModel3D x:Name="MapImagePlaneModel"/>
                <hx:MeshGeometryModel3D x:Name="TerrainModel"/>
                <hx:GroupModel3D x:Name="WeatherGridGroup"/>
                <hx:GroupModel3D x:Name="ContourGroup"/>
                <hx:GroupModel3D x:Name="WindGridGroup"/>
                <hx:GroupModel3D x:Name="StreamLineGroup"/>
                <hx:GroupModel3D x:Name="StationGroup"/>
                <hx:GroupModel3D x:Name="LabelGroup"/>
            </hx:GroupModel3D>
        </hx:Viewport3DX>

        <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Background="#88000000">
            <Button Content="CSV読込" Click="LoadCsv_Click" Margin="4" Padding="8,4"/>
            <Button Content="GRIB2読込" Click="LoadGrib2_Click" Margin="4" Padding="8,4"/>
            <Button Content="地図タイル取得" Click="DownloadMapTiles_Click" Margin="4" Padding="8,4"/>
            <Button Content="気温" Click="Temperature_Click" Margin="4" Padding="8,4"/>
            <Button Content="降水量" Click="Precipitation_Click" Margin="4" Padding="8,4"/>
            <Button Content="風速" Click="WindSpeed_Click" Margin="4" Padding="8,4"/>
            <Button Content="風ベクトル" Click="WindVector_Click" Margin="4" Padding="8,4"/>
            <Button Content="格子風" Click="WindGrid_Click" Margin="4" Padding="8,4"/>
            <Button Content="流線" Click="StreamLine_Click" Margin="4" Padding="8,4"/>
            <Button Content="気温面" Click="TemperatureGrid_Click" Margin="4" Padding="8,4"/>
            <Button Content="降水面" Click="PrecipitationGrid_Click" Margin="4" Padding="8,4"/>
            <Button Content="真上" Click="TopView_Click" Margin="4" Padding="8,4"/>
            <Button Content="斜め" Click="ObliqueView_Click" Margin="4" Padding="8,4"/>
            <Button Content="横" Click="SideView_Click" Margin="4" Padding="8,4"/>
            <Button Content="回転ON/OFF" Click="RotateToggle_Click" Margin="4" Padding="8,4"/>
            <Button Content="画像保存" Click="SaveImage_Click" Margin="4" Padding="8,4"/>
        </WrapPanel>

        <TextBlock x:Name="ModeTitle" Text="表示：気温" Foreground="White" Background="#88000000"
                   FontSize="20" FontWeight="Bold" Padding="10" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,92,0,0"/>

        <StackPanel x:Name="LegendPanel" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Background="#88000000" Width="230">
            <TextBlock Text="凡例" Foreground="White" FontWeight="Bold" FontSize="16" Margin="8"/>
            <TextBlock x:Name="LegendText" Foreground="White" FontSize="14" Margin="8" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10" Background="#88000000">
            <TextBlock Text="時刻" Foreground="White" VerticalAlignment="Center" Margin="8"/>
            <Slider x:Name="TimeSlider" Width="420" Minimum="0" Maximum="0" ValueChanged="TimeSlider_ValueChanged" Margin="8"/>
            <TextBlock x:Name="TimeText" Text="---" Foreground="White" VerticalAlignment="Center" Margin="8"/>
            <Button x:Name="PlayButton" Content="再生" Click="PlayButton_Click" Margin="8" Padding="8,4"/>
        </StackPanel>

        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8" Padding="6"
                   Foreground="White" Background="#88000000" FontSize="12"
                   Text="出典：地理院タイル（国土地理院）を加工して作成"/>
    </Grid>
</Window>
